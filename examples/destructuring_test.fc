// destructuring_test.fc - Test pattern destructuring
// Compile with: falcon build destructuring_test.fc

import string;

struct Point { x: i64, y: i64 }

func main() {
    // Test struct destructuring
    let p = Point { x: 10, y: 20 };
    let Point { x, y } = p;
    print_int(x);
    print_int(y);

    // Test with computed struct
    let p2 = Point { x: 100, y: 200 };
    let Point { x, y } = p2;
    print_int(x);
    print_int(y);
}
