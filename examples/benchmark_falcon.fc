// benchmark_falcon.fc — Falcon Benchmark: Sum 1 to 10,000,000
// Same algorithm as benchmark.c for fair comparison

import string;

func main() {
    let mut sum: i64 = 0;
    let mut i: i64 = 1;
    while i <= 10000000 {
        sum = sum + i;
        i = i + 1;
    }
    println("Falcon done");
}
