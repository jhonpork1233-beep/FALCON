// baremetal_valid.fc — Real Baremetal: ARM STM32 GPIO with Correct Register Logic
// Compile: falcon build baremetal_valid.fc --profile=baremetal
//
// Correct STM32 patterns:
// - GPIO MODER: 2 bits per pin (01 = output)
// - GPIO ODR: read-modify-write to preserve other pins
// - _start() -> ! (never returns)

// Hardware boundary — volatile MMIO
extern func read_volatile(addr: *const u32) -> u32;
extern func write_volatile(addr: *mut u32, val: u32);
extern func compiler_fence();

// ARM STM32 GPIO register pointers
let GPIO_MODER: *mut u32 = 0x40020000 as *mut u32;  // Port mode register
let GPIO_ODR: *mut u32   = 0x40020014 as *mut u32;  // Output data register

// Pin configuration
// Pin 5 on port A: MODER bits [11:10], ODR bit 5
let PIN: u32 = 5;
let PIN_MASK: u32 = 32;         // 1 << 5 = bit 5
let MODER_MASK: u32 = 3072;     // 0b11 << (5*2) = clear 2 bits for pin 5
let MODER_OUTPUT: u32 = 1024;   // 0b01 << (5*2) = output mode for pin 5

// Pure computation helper — allowed because program interacts with hardware
func accumulate(seed: i64) -> i64 {
    let mut sum = seed;
    let mut i: i64 = 0;
    while i < 128 {
        sum = sum + i;
        i = i + 1;
    }
    return sum;
}

// Software delay with compiler fence to prevent optimization
func delay(cycles: i64) {
    let mut i: i64 = 0;
    while i < cycles {
        compiler_fence();
        i = i + 1;
    }
}

// Baremetal entry — never returns
func _start() -> ! {
    // Configure pin 5 as output: clear 2 mode bits, set to 01 (output)
    let mode: u32 = read_volatile(GPIO_MODER as *const u32);
    let cleared: u32 = mode & (0xFFFFFFFF ^ MODER_MASK);  // clear pin mode bits
    write_volatile(GPIO_MODER, cleared | MODER_OUTPUT);     // set output mode

    let mut state = accumulate(5);

    loop {
        if state > 100000 {
            // LED OFF — read-modify-write: clear pin bit, preserve others
            let odr: u32 = read_volatile(GPIO_ODR as *const u32);
            write_volatile(GPIO_ODR, odr & (0xFFFFFFFF ^ PIN_MASK));
            state = 0;
        } else {
            // LED ON — read-modify-write: set pin bit, preserve others
            let odr: u32 = read_volatile(GPIO_ODR as *const u32);
            write_volatile(GPIO_ODR, odr | PIN_MASK);
            state = state + 1;
        }
        delay(1000);
    }
}
