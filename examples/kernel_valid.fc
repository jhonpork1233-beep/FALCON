// kernel_valid.fc — Valid Kernel Code (x86)
// Compile: falcon build kernel_valid.fc --profile=kernel --target=x86_64-unknown-none
//
// Valid kernel patterns: computation + properly initialized serial I/O

// x86 port I/O — typed hardware boundary
extern func outb(port: u16, val: u8);
extern func inb(port: u16) -> u8;

func kernel_compute(a: i32, b: i32) -> i32 {
    let result = a + b;
    return result * 2;
}

func kernel_array_ops() -> i32 {
    let data = [1, 2, 3, 4, 5];
    return data[0] + data[4];
}

func shared_add(x: i32, y: i32) -> i32 {
    return x + y;
}

// Initialize COM1 serial port (0x3F8)
// Sets: 9600 baud, 8N1, FIFO enabled
func serial_init() {
    outb(0x3F9 as u16, 0);     // Disable interrupts
    outb(0x3FB as u16, 0x80);  // Enable DLAB (set baud rate divisor)
    outb(0x3F8 as u16, 0x0C);  // Divisor low byte: 9600 baud
    outb(0x3F9 as u16, 0);     // Divisor high byte
    outb(0x3FB as u16, 0x03);  // 8 bits, no parity, 1 stop bit
    outb(0x3FA as u16, 0xC7);  // Enable FIFO, clear, 14-byte threshold
    outb(0x3FC as u16, 0x0B);  // IRQs enabled, RTS/DSR set
}

// Wait for transmitter holding register empty, then send byte
func serial_write(byte: u8) {
    loop {
        let status: u8 = inb(0x3FD as u16);
        if (status & 0x20) != 0 {
            break;
        }
    }
    outb(0x3F8 as u16, byte);
}

// Kernel entry — never returns
func _start() -> ! {
    serial_init();

    let mut heartbeat = shared_add(kernel_compute(10, 20), kernel_array_ops());

    // Print "GO\n" to serial
    serial_write(71);  // G
    serial_write(79);  // O
    serial_write(10);  // \n

    loop {
        heartbeat = heartbeat + 1;
        if heartbeat > 1000000 {
            heartbeat = 0;
            serial_write(46);  // '.'
        }
    }
}
