# Stress Test - Python-style Falcon
# Performance test with heavy computation

import string
def main():
    println("=== Falcon Stress Test ===")
    
    # Test 1: Large sum
    println("Test 1: Sum 1 to 100 million...")
    let mut sum: i64 = 0
    let mut i: i64 = 1
    while i <= 100000000:
        sum = sum + i
        i = i + 1
    print("Sum: ")
    print_int(sum)
    println("")
    
    # Test 2: Nested loops
    println("Test 2: Nested loops 1000x1000...")
    let mut count = 0
    let mut j = 0
    while j < 1000:
        let mut k = 0
        while k < 1000:
            count = count + 1
            k = k + 1
        j = j + 1
    print("Iterations: ")
    print_int(count)
    println("")
    
    println("=== Stress Test Complete ===")
