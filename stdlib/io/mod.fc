// Convenience functions
pub func read_to_string(path: &str) -> Result<String, String> {
    let mut file = File::open(path)?;
    file.read_to_string()
}

pub func write(path: &str, data: &str) -> Result<(), String> {
    let mut file = File::create(path)?;
    file.write(data.as_bytes())?;
    Ok(())
}









